# Supabase
VITE_SUPABASE_URL=your_supabase_project_url
VITE_SUPABASE_PUBLISHABLE_KEY=your_supabase_anon_key

# Google Maps
VITE_GOOGLE_MAPS_API_KEY=your_google_maps_browser_key_here

# Daily.co (Video Consultations)
VITE_DAILY_API_KEY=your_daily_api_key

# SearchAPI (Currency Conversion)
VITE_SEARCH_API_KEY=your_searchapi_key

# AI providers para triagem multicamada (coloque as chaves reais em .env.local, NÃO aqui)
# Cadeia de fallback: Edge Function → Gemini → Groq → OpenRouter → Regras clínicas locais
# VITE_GEMINI_API_KEY=        # https://aistudio.google.com/apikey
# VITE_GROQ_API_KEY=          # https://console.groq.com/keys
# VITE_OPENROUTER_API_KEY=    # https://openrouter.ai/keys
